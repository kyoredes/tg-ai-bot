DEBUG=true
LOG_LEVEL=INFO
GRPC_HOST=0.0.0.0
GRPC_PORT=50053

REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# LiteLLM (primary LLM provider in production)
LITELLM_MODEL=gpt-3.5-turbo
LITELLM_TEMPERATURE=0.2
LITELLM_MAX_TOKENS=3000
LITELLM_API_KEY=
LITELLM_API_BASE=
# LITELLM_CUSTOM_PROVIDER=openai

# Legacy fallbacks when LITELLM_API_KEY / LITELLM_API_BASE are empty
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Shared chat history (LiteLLM + G4F)
# CHAT_HISTORY_KEY_PREFIX=chat_history:
# CHAT_HISTORY_TTL_SECONDS=604800
# CHAT_HISTORY_MAX_MESSAGES=20
# CHAT_HISTORY_MAX_WORDS_PER_MESSAGE=400
# CHAT_HISTORY_MAX_TOTAL_WORDS=3000
