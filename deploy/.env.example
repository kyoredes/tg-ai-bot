BOT_TOKEN=
COMMON_PUB_KEY=secret
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-prod!!

# Admin panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_JWT_SECRET=admin-jwt-secret-change-in-prod
ADMIN_CORS_ORIGIN=http://localhost:3000

# ai-service: DEBUG=true uses G4F only, false uses LiteLLM+G4F fallback
AI_DEBUG=true
LITELLM_MODEL=gpt-3.5-turbo
LITELLM_TEMPERATURE=0.2
LITELLM_MAX_TOKENS=3000
LITELLM_API_KEY=
LITELLM_API_BASE=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Gateway / aiogram HTTP timeouts (seconds)
GATEWAY_TIMEOUT=120s
HTTP_TIMEOUT=120

# Throttling (shared defaults; override per service in docker-compose)
THROTTLE_ENABLED=true
THROTTLE_LIMIT=300
THROTTLE_WINDOW=60s
THROTTLE_CHAT_LIMIT=10
THROTTLE_CHAT_WINDOW=60s
THROTTLE_LOGIN_LIMIT=10
THROTTLE_LOGIN_WINDOW=60s
THROTTLE_WINDOW_SECONDS=60
THROTTLE_CHAT_WINDOW_SECONDS=60
THROTTLE_BAN_SECONDS=100
